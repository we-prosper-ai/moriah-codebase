# CoachTinaMarie Backend Configuration
PORT=3333
NODE_ENV=development

# Anthropic API (for coaching responses)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DB_PATH=./coachtina.db

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Auth (simple API key for service-to-service)
API_SECRET_KEY=change_me_in_production

# Coaching settings
COACHING_MODEL=claude-opus-4-5
MAX_COACHING_TURNS=50
SESSION_TIMEOUT_HOURS=24
