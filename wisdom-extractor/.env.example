# Wisdom Extractor — Environment Variables

# Required: Anthropic API key
ANTHROPIC_API_KEY=your_key_here

# Optional: Override the Claude model (default: claude-opus-4-5)
CLAUDE_MODEL=claude-opus-4-5

# Optional: Port (default: 4002)
PORT=4002

# Optional: SQLite database path (default: data/db/wisdom.db)
DB_PATH=

# Optional: CoachTinaMarie sync endpoint
COACHTINA_URL=http://localhost:4003/teachings/ingest

# Optional: Store full prompts/responses in audit records (default: false)
AUDIT_STORE_PROMPTS=false
AUDIT_STORE_RESPONSES=false
